###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=change_this_to_a_random_32char_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME?serverVersion=8.0
DATABASE_URL=DATABASE_URL="mysql://${MYSQLUSER}:${MYSQLPASSWORD}@${MYSQLHOST}:${MYSQLPORT}/${MYSQLDATABASE}?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> MySQL Container Settings ###
MYSQL_DATABASE=symfony_db
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=symfony_user
MYSQL_PASSWORD=symfony_pass
DB_HOST=db
###< MySQL Container Settings ###

###> Railway Deployment ###
# When deploying to Railway, set these in the Railway dashboard
# under your service > Variables. Do NOT commit real values to Git.
# DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DBNAME?serverVersion=8.0
